<!--page/tabBar/component/index/index.wxml-->
<!--简介: 组件 Tab 首页视图, 展示宿主小程序列表, 支持左滑置顶/删除、右滑开抽屉、顶部下拉添加面板-->
<!--履历: 2026-07-23 重写: 左滑用纯 touch 计算位移(弃用 movable-view); 右滑开抽屉挂根容器; 未展开时按钮层 opacity 隐藏防缝隙透出-->
<!--履历: 2026-07-23 抽屉"我的收藏/设置"合并为"检查更新", 接入 wx.getUpdateManager() 触发小程序远程更新-->
<!--履历: 2026-07-23 新增更新进度覆盖层: 进度条实时展示宿主 MiniAppUpdate.progress 上报的真实下载/安装百分比, 未知时走不确定态-->
<view class="page-wrap"
  bindtouchstart="onPageTouchStart"
  bindtouchend="onPageTouchEnd"
>
  <!-- 顶部导航栏: 仿 QQ, 左上角头像+昵称+在线状态(点开抽屉), 右上角加号(点开菜单) -->
  <view class="navbar" style="padding-top: calc({{statusBarHeight}}px + 16rpx);">
    <view class="nav-left" bindtap="openDrawer">
      <view class="nav-avatar">{{avatarText}}</view>
      <view class="nav-user">
        <text class="nav-name">{{nickName}}</text>
        <text class="nav-status">{{onlineStatus}}</text>
      </view>
    </view>
    <view class="nav-right">
      <view class="nav-add" bindtap="toggleMenu">
        <text class="nav-add-icon">+</text>
      </view>
    </view>
  </view>

  <scroll-view
    class="page"
    scroll-y="{{!swipeLock}}"
    refresher-enabled="{{true}}"
    refresher-default-style="none"
    bindrefresherrefresh="onRefresherRefresh"
    refresher-triggered="{{triggered}}"
    bindscroll="onListScroll"
  >
    <view class="search">
      <input
        class="search-input"
        placeholder="搜索小程序"
        placeholder-class="search-ph"
        value="{{keywords}}"
        bindinput="onSearchInput"
      />
    </view>

    <view class="list" bindtap="onListTap">
      <view
        class="swipe-item"
        wx:for="{{displayList}}"
        wx:key="appId"
        data-appid="{{item.appId}}"
        bindtouchstart="onSwipeTouchStart"
        bindtouchmove="onSwipeTouchMove"
        bindtouchend="onSwipeTouchEnd"
        bindtouchcancel="onSwipeTouchEnd"
        bindtap="onSwipeTap"
      >
        <!-- 操作按钮置于内容层之下(右侧), 内容层左移时露出的即按钮;
             左滑位移由 onSwipeTouchMove 直接写入 item.translateX(px), 不再依赖 movable-view -->
        <view class="swipe-actions {{item.translateX < 0 ? 'open' : ''}}">
          <view class="swipe-btn top" data-appid="{{item.appId}}" catchtap="onTopItem">置顶</view>
          <view class="swipe-btn del" data-appid="{{item.appId}}" catchtap="onDeleteItem">删除</view>
        </view>
        <view class="swipe-content {{swipeLock ? 'no-anim' : ''}}" style="transform: translateX({{item.translateX}}px);">
          <view class="avatar" style="background:{{item.color}}">{{item.avatar}}</view>
          <text class="name">{{item.name}}</text>
        </view>
      </view>
    </view>

    <view class="empty" wx:if="{{displayList.length === 0}}">
      <text>暂无小程序</text>
    </view>
  </scroll-view>

  <view class="footer">版本 {{version}}</view>

  <!-- 下拉面板: 添加小程序 -->
  <view
    class="pull-mask {{panelTransition ? 'transition' : ''}}"
    style="transform: translateY({{panelY}}px); opacity: {{panelOpacity}};"
  >
    <view
      class="pull-panel"
      catchtouchstart="onPullStart"
      catchtouchmove="onPullMove"
      catchtouchend="onPullEnd"
      data-role="panel"
    >
      <!-- 面板右上角关闭按钮 -->
      <view class="pull-panel-close" catchtap="closePanel">×</view>

      <text class="pull-panel-title">添加小程序</text>

      <view class="add-form">
        <input
          class="add-input"
          placeholder="小程序 appId (如 wx1234567890)"
          placeholder-class="add-ph"
          value="{{newAppId}}"
          bindinput="onAppIdInput"
        />
        <input
          class="add-input"
          placeholder="小程序名称"
          placeholder-class="add-ph"
          value="{{newName}}"
          bindinput="onNameInput"
        />
        <input
          class="add-input"
          placeholder="入口路径(可选, 如 page/index/index)"
          placeholder-class="add-ph"
          value="{{newPath}}"
          bindinput="onPathInput"
        />
        <button class="add-btn" bindtap="onAddMiniProgram">添加</button>
      </view>
    </view>
  </view>

  <!-- 左侧抽屉: 点击左上角头像/昵称弹出 -->
  <view class="drawer-mask {{drawerOpen ? 'show' : ''}}" bindtap="closeDrawer" bindtouchstart="onDrawerTouchStart" bindtouchend="onDrawerTouchEnd">
    <view class="drawer {{drawerOpen ? 'open' : ''}}" catchtap="noop">
      <view class="drawer-profile">
        <view class="drawer-avatar">{{avatarText}}</view>
        <text class="drawer-name">{{nickName}}</text>
        <text class="drawer-status">{{onlineStatus}}</text>
      </view>
      <view class="drawer-menu">
        <view class="drawer-item" bindtap="onDrawerItem" data-key="update">检查更新</view>
        <view class="drawer-item" bindtap="onDrawerItem" data-key="exit">退出登录</view>
      </view>
    </view>
  </view>

  <!-- 右上角下拉菜单: 点击加号弹出, 含扫一扫等 -->
  <view class="menu-mask {{menuOpen ? 'show' : ''}}" bindtap="closeMenu">
    <view class="menu {{menuOpen ? 'show' : ''}}" catchtap="noop">
      <view class="menu-item" bindtap="onScan">
        <text class="menu-item-text">扫一扫</text>
      </view>
      <view class="menu-item" bindtap="onMenuAddFriend">
        <text class="menu-item-text">添加好友</text>
      </view>
    </view>
  </view>

  <!-- 更新进度覆盖层: 检查/下载/安装阶段, 进度条实时展示宿主上报的真实百分比 -->
  <view class="update-mask {{showProgress ? 'show' : ''}}">
    <view class="update-card">
      <text class="update-title">{{updateStage === 'install' ? '安装中...' : (updateStage === 'check' ? '检查更新中...' : (updatePercent >= 0 ? '下载中 ' + updatePercent + '%' : '下载中...'))}}</text>
      <view class="update-bar">
        <view class="update-bar-inner {{updatePercent < 0 ? 'indeterminate' : ''}}" style="width: {{updatePercent < 0 ? 100 : updatePercent}}%;"></view>
      </view>
    </view>
  </view>
</view>
