/* page/tabBar/component/index/index.wxss */
/* 简介: 组件 Tab 首页样式, 小程序列表(仿宿主 MainActivity), 支持左滑置顶/删除 */
/* 履历: 2026-07-22 新增小程序列表样式, 参考宿主 MainActivity */
/* 履历: 2026-07-22 页面改为 flex 列布局, 底部新增版本号 footer */
/* 履历: 2026-07-23 列表项改为左滑操作, 新增 swipe-item / swipe-actions / swipe-front 样式 */
.page-wrap {
  height: 100vh;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  background: #F5F5F5;
}

.page {
  flex: 1;
  box-sizing: border-box;
  overflow: hidden;
  /* 顶部间距: 系统状态栏已由 navbar(statusBarHeight) 预留, 此处不再叠加 env(safe-area-inset-top),
     否则搜索条会整体下移一整条状态栏高度, 与导航栏间距过大 */
  padding: 24rpx 24rpx 24rpx;
  -webkit-overflow-scrolling: touch;
}

.footer {
  flex-shrink: 0;
  text-align: center;
  font-size: 24rpx;
  color: #999;
  padding: 16rpx 0 calc(16rpx + env(safe-area-inset-bottom));
}

.search {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 0 24rpx;
  height: 92rpx;
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #1F2329;
}

.search-ph {
  color: #86909C;
}

.list {
  background: #FFFFFF;
  border-radius: 16rpx;
  overflow: hidden;
}

.swipe-item {
  position: relative;
  height: 152rpx;
  overflow: hidden;
}

/* 操作按钮层: 绝对定位在右侧, 位于内容层之下; 内容层左移时被露出 */
/* 未展开(transl<0 即 .open)时 opacity:0 隐藏, 避免相邻项缝隙透出彩色按钮; 展开态才显示并响应点击 */
.swipe-actions {
  position: absolute;
  right: 0;
  top: 0;
  width: 320rpx;
  height: 100%;
  display: flex;
  flex-direction: row;
  opacity: 0;
  transition: opacity 0.18s ease;
  /* 未展开时不响应点击, 避免覆盖在内容右侧的隐藏按钮误触发 */
  pointer-events: none;
}

.swipe-actions.open {
  opacity: 1;
  pointer-events: auto;
}

/* 内容层: 默认盖住按钮; 左滑时 translateX 为负露出按钮; no-anim 在横向拖拽时关闭过渡, 1:1 跟手 */
.swipe-content {
  position: relative;
  z-index: 1;
  width: 100%;
  height: 100%;
  background: #FFFFFF;
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  box-sizing: border-box;
  transform: translateX(0);
  transition: transform 0.2s ease;
  will-change: transform;
}

.swipe-content.no-anim {
  transition: none;
}

.swipe-content::after {
  content: '';
  position: absolute;
  left: 120rpx;
  right: 0;
  bottom: 0;
  height: 1rpx;
  background: #EEEEEE;
}

.swipe-item:last-child .swipe-content::after {
  display: none;
}

.swipe-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #FFFFFF;
  font-size: 30rpx;
}

.swipe-btn.top {
  background: #07C160;
}

.swipe-btn.del {
  background: #FF4D4F;
}

.avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  color: #FFFFFF;
  font-size: 44rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.name {
  font-size: 32rpx;
  color: #1F2329;
}

.empty {
  text-align: center;
  color: #999;
  font-size: 28rpx;
  padding: 80rpx 0;
}

/* 履历: 2026-07-22 下拉交互改为列表滚到顶下拉唤出面板 / 面板整体上滑关闭, 移除把手 */

/* 下拉面板: 全屏遮罩 + 白色面板, 默认在视口上方(关闭) */
.pull-mask {
  position: fixed;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  z-index: 100;
  background: rgba(0, 0, 0, 0.35);
  transform: translateY(-100%);
  display: flex;
  flex-direction: column;
}

.pull-mask.transition {
  transition: transform 0.3s ease, opacity 0.3s ease;
}

.pull-panel {
  background: #FFFFFF;
  height: 100%;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  padding: calc(env(safe-area-inset-top) + 24rpx) 40rpx 40rpx;
  overflow-y: auto;
  position: relative;
}

.pull-panel-close {
  position: absolute;
  top: calc(env(safe-area-inset-top) + 16rpx);
  right: 24rpx;
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: #86909C;
  z-index: 2;
}

.pull-panel-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #1F2329;
  margin: 16rpx 0 40rpx;
}

.add-form {
  display: flex;
  flex-direction: column;
}

.add-input {
  height: 96rpx;
  background: #F5F5F5;
  border-radius: 16rpx;
  padding: 0 28rpx;
  font-size: 28rpx;
  color: #1F2329;
  margin-bottom: 24rpx;
  box-sizing: border-box;
}

.add-ph {
  color: #86909C;
}

.add-btn {
  margin-top: 16rpx;
  background: #07C160;
  color: #FFFFFF;
  font-size: 32rpx;
  border-radius: 16rpx;
}

/* 履历: 2026-07-22 新增仿 QQ 顶栏 / 左侧抽屉 / 右上角加号下拉菜单 */
/* 履历: 2026-07-22 优化下拉/上滑交互: 橡皮筋阻尼 + 速度甩动 + 关闭按钮 + 面板可滚动 */
/* 履历: 2026-07-22 沉浸式状态栏: navbar 顶部由内联 statusBarHeight 预留, 不再用 safe-area-inset-top */
/* 履历: 2026-07-22 下拉交互改为: 列表滚到顶下拉唤出 / 面板整体上滑关闭(移除把手) / 滚动增强 */
/* 履历: 2026-07-22 导航栏加高: 状态栏区域 +16rpx, navbar 内容区与头像字号放大, 菜单下落位置同步下移 */
/* 履历: 2026-07-23 搜索条与导航栏间距合理化: 去掉 .page 顶部重复的安全区内边距(状态栏已由 navbar 预留), 改 24rpx 对齐 navbar 底距 */
/* 顶部导航栏(顶部状态栏高度由内联 style 的 statusBarHeight+16rpx 预留, 不再用 safe-area, 避免无刘海设备重叠) */
.navbar {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-left: 28rpx;
  padding-right: 28rpx;
  padding-bottom: 24rpx;
  background: #FFFFFF;
  border-bottom: 1rpx solid #EEEEEE;
}

.nav-left {
  display: flex;
  align-items: center;
}

.nav-avatar {
  width: 92rpx;
  height: 92rpx;
  border-radius: 50%;
  background: #07C160;
  color: #FFFFFF;
  font-size: 40rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
}

.nav-user {
  display: flex;
  flex-direction: column;
}

.nav-name {
  font-size: 34rpx;
  color: #1F2329;
  font-weight: 600;
}

.nav-status {
  font-size: 24rpx;
  color: #07C160;
  margin-top: 6rpx;
}

.nav-status::before {
  content: '';
  display: inline-block;
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #07C160;
  margin-right: 8rpx;
  vertical-align: middle;
}

.nav-right {
  display: flex;
  align-items: center;
}

.nav-add {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-add-icon {
  font-size: 56rpx;
  color: #1F2329;
  line-height: 1;
  font-weight: 300;
}

/* 左侧抽屉 */
.drawer-mask {
  position: fixed;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.4);
  z-index: 200;
  opacity: 0;
  visibility: hidden;
  transition: opacity 0.3s ease, visibility 0.3s ease;
}

.drawer-mask.show {
  opacity: 1;
  visibility: visible;
}

.drawer {
  position: absolute;
  left: 0;
  top: 0;
  height: 100%;
  width: 72%;
  background: #FFFFFF;
  transform: translateX(-100%);
  transition: transform 0.3s ease;
  display: flex;
  flex-direction: column;
}

.drawer.open {
  transform: translateX(0);
}

.drawer-profile {
  padding: calc(env(safe-area-inset-top) + 56rpx) 40rpx 48rpx;
  background: #07C160;
  color: #FFFFFF;
}

.drawer-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.25);
  font-size: 52rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
}

.drawer-name {
  font-size: 38rpx;
  font-weight: 600;
  display: block;
}

.drawer-status {
  font-size: 24rpx;
  opacity: 0.9;
  display: block;
  margin-top: 8rpx;
}

.drawer-menu {
  padding: 16rpx 0;
}

.drawer-item {
  padding: 32rpx 40rpx;
  font-size: 30rpx;
  color: #1F2329;
  border-bottom: 1rpx solid #F2F2F2;
}

/* 右上角下拉菜单 */
.menu-mask {
  position: fixed;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  z-index: 150;
  opacity: 0;
  visibility: hidden;
  transition: opacity 0.2s ease, visibility 0.2s ease;
}

.menu-mask.show {
  opacity: 1;
  visibility: visible;
}

.menu {
  position: absolute;
  top: calc(env(safe-area-inset-top) + 132rpx);
  right: 24rpx;
  background: #FFFFFF;
  border-radius: 12rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.15);
  min-width: 240rpx;
  transform: scale(0.9);
  transform-origin: top right;
  opacity: 0;
  transition: transform 0.2s ease, opacity 0.2s ease;
}

.menu.show {
  transform: scale(1);
  opacity: 1;
}

.menu-item {
  padding: 28rpx 32rpx;
  font-size: 30rpx;
  color: #1F2329;
  display: flex;
  align-items: center;
}

.menu-item + .menu-item {
  border-top: 1rpx solid #F2F2F2;
}

.menu-item-text {
  color: #1F2329;
}
