/* page/tabBar/component/index/index.wxss */
/* 简介: 组件 Tab 首页样式, 小程序列表(仿宿主 MainActivity) */
/* 履历: 2026-07-22 新增小程序列表样式, 参考宿主 MainActivity */
.page {
  height: 100vh;
  box-sizing: border-box;
  padding: calc(env(safe-area-inset-top) + 32rpx) 24rpx calc(24rpx + env(safe-area-inset-bottom));
  background: #F5F5F5;
}

.header {
  text-align: center;
  padding: 16rpx 0 24rpx;
}

.header-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1F2329;
}

.search {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 0 24rpx;
  height: 92rpx;
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #1F2329;
}

.search-ph {
  color: #86909C;
}

.list {
  background: #FFFFFF;
  border-radius: 16rpx;
  overflow: hidden;
}

.item {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  position: relative;
}

.item::after {
  content: '';
  position: absolute;
  left: 120rpx;
  right: 0;
  bottom: 0;
  height: 1rpx;
  background: #EEEEEE;
}

.item:last-child::after {
  display: none;
}

.avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  color: #FFFFFF;
  font-size: 44rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.name {
  font-size: 32rpx;
  color: #1F2329;
}

.empty {
  text-align: center;
  color: #999;
  font-size: 28rpx;
  padding: 80rpx 0;
}
