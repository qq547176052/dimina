<!--page/tabBar/component/max_image/max_image.wxml-->
<!--简介: 推送落地页视图, 按推送字段展示: 标题/内容/全景图/人脸图-->
<!--履历: 2026-07-21 创建, 通用参数列表+原始数据展示-->
<!--履历: 2026-07-21 按推送字段重构界面, 仅保留 标题/内容/全景图/人脸图, 移除返回按钮与调试区-->
<!--履历: 2026-07-21 排序调整为 标题/内容/人脸图/全景图, 整体底部对齐, 顶部留 1/15 屏高外边距-->
<!--履历: 2026-07-21 内容超出一屏时默认滚动到底部(scroll-into-view), 内层 flex 底部对齐避免顶部被裁-->
<!--履历: 2026-07-22 全景图加载失败增加点 击重试按钮; 点击全景图打开自建放大层(movable 双指缩放+拖动+点击关闭)-->
<!--履历: 2026-07-22 放大层改用 movable-view scale+out-of-bounds, 放大后可自由拖动; 关闭按钮加大并下移左移-->
<!--履历: 2026-07-23 放大层改自定义手势(单指拖动+双指缩放), 去掉点击图片关闭避免误触, 仅点×关闭-->
<scroll-view class="page" scroll-y scroll-into-view="{{scrollIntoView}}" wx:if="{{received}}">
  <view class="inner">
    <view class="card head">
      <text class="title">{{title}}</text>
      <text class="content">{{content}}</text>
    </view>

    <view class="card" wx:if="{{faceImage}}">
      <view class="label">人脸图</view>
      <image class="face" src="{{faceImage}}" mode="aspectFill"></image>
    </view>

    <view class="card" id="maxBottom">
      <view class="label">全景图</view>
      <image
        wx:if="{{panoImage && !imgError}}"
        class="pano"
        src="{{panoImage}}"
        mode="widthFix"
        show-menu-by-longpress
        binderror="onImageError"
        bindtap="openPreview"
      ></image>
      <view class="err-box" wx:if="{{imgError}}">
        <text class="err">全景图加载失败, 请检查网络或地址</text>
        <button class="retry-btn" size="mini" bindtap="onRetry">点击重试</button>
      </view>
    </view>
  </view>
</scroll-view>

<view class="empty" wx:else>
  <text>未接收到推送参数</text>
</view>

<!-- 自建全景图放大层: 双指缩放, 单指拖动查看, 仅点×关闭(避免误触) -->
<view class="preview-mask" wx:if="{{preview}}">
  <view
    class="preview-stage"
    catchtouchstart="onImgTouchStart"
    catchtouchmove="onImgTouchMove"
    catchtouchend="onImgTouchEnd"
    catchtouchcancel="onImgTouchEnd"
  >
    <image
      class="preview-img {{imgAnim ? 'anim' : ''}}"
      src="{{panoImage}}"
      mode="widthFix"
      style="transform: translate({{imgX}}px, {{imgY}}px) scale({{imgScale}}) rotate({{rotate}}deg);"
    ></image>
  </view>
  <view class="preview-close" catchtap="closePreview">×</view>
  <view class="preview-rotate" catchtap="onRotate">旋转</view>
  <text class="preview-tip">双指缩放 · 单指拖动 · 点×关闭</text>
</view>
