/* page/tabBar/component/max_image/max_image.wxss */
/* 简介: 推送落地页样式, 按字段结构化卡片展示 标题/内容/全景图/人脸图 */
/* 履历: 2026-07-21 创建 */
/* 履历: 2026-07-21 按推送字段重构样式, 移除状态条/返回按钮/原始数据/通用参数样式 */
/* 履历: 2026-07-21 顶部/底部留白适配刘海与安全区(viewport-fit=cover) */
/* 履历: 2026-07-21 整体底部对齐, 顶部外边距占屏高 1/15 */
/* 履历: 2026-07-21 底部对齐移至内层 .inner, 长内容可正常滚动且默认滚到底部 */
/* 履历: 2026-07-22 .inner 由底部对齐改为上下居中(justify-content: center) */
/* 履历: 2026-07-22 增加加载失败重试按钮与自建全景图放大层样式 */
/* 履历: 2026-07-22 放大层 movable-view 加 out-of-bounds 支持放大后拖动; 关闭按钮 96rpx 并下移左移 */
/* 履历: 2026-07-23 放大层弃用 movable, 改 preview-stage 承接自定义手势, 图片由 inline transform 驱动 */
.page {
  height: 100vh;
  box-sizing: border-box;
  padding: calc(env(safe-area-inset-top) + 100vh / 15) 24rpx calc(24rpx + env(safe-area-inset-bottom));
  background: #f5f6f8;
}

.inner {
  min-height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.card:last-child {
  margin-bottom: 0;
}

.title {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.content {
  display: block;
  margin-top: 16rpx;
  font-size: 28rpx;
  color: #555;
  line-height: 1.6;
}

.label {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 16rpx;
}

.pano {
  width: 100%;
  border-radius: 12rpx;
  background: #eaecef;
}

.err-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 0;
}

.retry-btn {
  margin-top: 20rpx;
  color: #fff;
  background: #1aad19;
}

.face {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  background: #eaecef;
}

.empty {
  margin-top: 200rpx;
  text-align: center;
  color: #999;
  font-size: 28rpx;
}

/* ---- 自建全景图放大层 ---- */
.preview-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: #000;
  z-index: 999;
}

.preview-stage {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.preview-img {
  width: 100vw;
  will-change: transform;
}

.preview-img.anim {
  transition: transform 0.25s ease-out;
}

.preview-rotate {
  position: fixed;
  left: 50%;
  transform: translateX(-50%);
  bottom: calc(env(safe-area-inset-bottom) + 96rpx);
  padding: 0 40rpx;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  font-size: 28rpx;
  color: #fff;
  background: rgba(0, 0, 0, 0.5);
  border-radius: 36rpx;
  z-index: 1000;
}

.preview-close {
  position: fixed;
  top: calc(env(safe-area-inset-top) + 80rpx);
  right: 72rpx;
  width: 96rpx;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 64rpx;
  color: #fff;
  background: rgba(0, 0, 0, 0.5);
  border-radius: 50%;
  z-index: 1000;
}

.preview-tip {
  position: fixed;
  left: 0;
  right: 0;
  bottom: calc(env(safe-area-inset-bottom) + 40rpx);
  text-align: center;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  z-index: 1000;
}
