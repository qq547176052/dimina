/* page/tabBar/component/max_image/max_image.wxss */
/* 简介: 推送落地页样式, 按字段结构化卡片展示 标题/内容/全景图/人脸图 */
/* 履历: 2026-07-21 创建 */
/* 履历: 2026-07-21 按推送字段重构样式, 移除状态条/返回按钮/原始数据/通用参数样式 */
/* 履历: 2026-07-21 顶部/底部留白适配刘海与安全区(viewport-fit=cover) */
/* 履历: 2026-07-21 整体底部对齐, 顶部外边距占屏高 1/15 */
/* 履历: 2026-07-21 底部对齐移至内层 .inner, 长内容可正常滚动且默认滚到底部 */
/* 履历: 2026-07-22 .inner 由底部对齐改为上下居中(justify-content: center) */
.page {
  height: 100vh;
  box-sizing: border-box;
  padding: calc(env(safe-area-inset-top) + 100vh / 15) 24rpx calc(24rpx + env(safe-area-inset-bottom));
  background: #f5f6f8;
}

.inner {
  min-height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.card:last-child {
  margin-bottom: 0;
}

.title {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.content {
  display: block;
  margin-top: 16rpx;
  font-size: 28rpx;
  color: #555;
  line-height: 1.6;
}

.label {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 16rpx;
}

.pano {
  width: 100%;
  border-radius: 12rpx;
  background: #eaecef;
}

.face {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  background: #eaecef;
}

.empty {
  margin-top: 200rpx;
  text-align: center;
  color: #999;
  font-size: 28rpx;
}
