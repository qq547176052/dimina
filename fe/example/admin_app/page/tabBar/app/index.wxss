.home {
  min-height: 100vh;
  background-color: #f8f8f8;
  padding: 80rpx 40rpx 40rpx;
  box-sizing: border-box;
}

.home-hd {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 60rpx;
}

.home-logo {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 20rpx;
}

.home-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
}

.home-version {
  margin-top: 8rpx;
  font-size: 26rpx;
  color: #999;
}

.home-bd {
  display: flex;
  flex-direction: column;
}

.home-card {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
}

.home-card-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.home-card-desc {
  margin-top: 8rpx;
  font-size: 26rpx;
  color: #999;
}
